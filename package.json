{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "sonar": "sonar-scanner -Dsonar.token=fc7fbb8edc0befafade0eff80805d0389421b368",
    "sonar:env": "sonar-scanner -Dsonar.token=%SONAR_TOKEN%",
    "cypress:open": "cypress open --config-file test/cypress.config.ts",
    "cypress:run": "cypress run --config-file test/cypress.config.ts",
    "test:performance": "start-server-and-test dev http://localhost:3000 cypress:run",
    "test:performance:headed": "start-server-and-test dev http://localhost:3000 'cypress run --headed --config-file test/cypress.config.ts'",
    "test:performance:chrome": "start-server-and-test dev http://localhost:3000 'cypress run --browser chrome --config-file test/cypress.config.ts'",
    "test:performance:report": "cypress run --config-file test/cypress.config.ts --reporter json --reporter-options output=test/reports/results.json",
    "test:ci": "start-server-and-test start http://localhost:3000 'cypress run --config-file test/cypress.config.ts --browser chrome'",
    "playwright:ci": "start-server-and-test start http://localhost:3000 'npx playwright test'",
    "playwright:test": "npx playwright test",
    "playwright:test:headed": "npx playwright test --headed",
    "playwright:test:ui": "npx playwright test --ui",
    "playwright:report": "npx playwright show-report test/playwright/reports",
    "test:e2e:lifecycle": "start-server-and-test dev http://localhost:3000 'npx playwright test service-lifecycle'"
  },
  "dependencies": {
    "@aws-sdk/client-sns": "^3.997.0",
    "@supabase/supabase-js": "^2.51.0",
    "@tanstack/react-query": "^5.90.7",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.525.0",
    "next": "15.3.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.28",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "cypress": "^15.8.2",
    "cypress-real-events": "^1.15.0",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "15.3.5",
    "postcss": "^8.5.6",
    "start-server-and-test": "^2.1.3",
    "tailwindcss": "^4.1.11",
    "typescript": "^5"
  }
}
