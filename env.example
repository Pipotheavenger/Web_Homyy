# Supabase Configuration
# Copia este archivo como .env.local y reemplaza los valores con tu configuración real de Supabase

NEXT_PUBLIC_SUPABASE_URL=tu_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_supabase_anon_key

# Instrucciones:
# 1. Ve a https://supabase.com/
# 2. Crea un nuevo proyecto
# 3. Ve a Settings > API
# 4. Copia los valores de URL y anon key
# 5. Crea un archivo .env.local en la raíz del frontend
# 6. Pega los valores reales de tu proyecto Supabase 